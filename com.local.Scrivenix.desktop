[Desktop Entry]
Name=Scrivenix
GenericName=Writing Application
Comment=Write Your Way — Scrivener 3 on Linux
Exec=scrivenix-wrapper
Icon=com.local.Scrivenix
Terminal=false
Type=Application
Categories=Office;WordProcessor;
# Wine window class for the Scrivener process.
# Use `xprop WM_CLASS` while Scrivener is open to confirm this value
# if taskbar grouping doesn't work correctly.
StartupWMClass=scrivener.exe
Keywords=Writing;Novel;Manuscript;Scrivener;Screenwriting;
# Declare the Settings action so the right-click menu appears in supported DEs
Actions=DisplaySettings;

[Desktop Action DisplaySettings]
Name=Display & Font Settings
Exec=scrivenix-wrapper --winecfg
Icon=preferences-desktop-display
